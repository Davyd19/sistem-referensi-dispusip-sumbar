<%- include('partials/header') %>

<div class="flex flex-col md:flex-row gap-8">
    
    <!-- SIDEBAR FILTER (Kiri) -->
    <aside class="w-full md:w-3/12 space-y-6">
        
        <!-- Panel Filter -->
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
            <div class="bg-blue-800 text-white px-4 py-3 font-bold text-sm">
                <i class="fas fa-filter mr-2"></i> Persempit Pencarian
            </div>
            
            <form action="/search" method="GET" id="filterForm" class="p-4">
                <!-- Hidden inputs -->
                <input type="hidden" name="q" value="<%= query.q || '' %>">
                <input type="hidden" name="searchBy" value="<%= query.searchBy || 'title' %>">
                <input type="hidden" name="matchType" value="<%= query.matchType || 'contains' %>">

                <!-- Filter Kategori -->
                <div class="mb-5">
                    <h4 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-3">Jenis Bahan</h4>
                    <div class="space-y-2 max-h-60 overflow-y-auto custom-scrollbar">
                        <label class="flex items-center space-x-2 cursor-pointer group">
                            <input type="radio" name="category" value="" onchange="this.form.submit()" 
                                <%= !query.category ? 'checked' : '' %> class="text-blue-600 focus:ring-blue-500">
                            <span class="text-sm text-gray-700 group-hover:text-blue-600">Semua Bahan</span>
                        </label>
                        <% sidebarData.categories.forEach(item => { %>
                            <label class="flex items-center space-x-2 cursor-pointer group">
                                <input type="radio" name="category" value="<%= item.category %>" 
                                    onchange="this.form.submit()"
                                    <%= query.category === item.category ? 'checked' : '' %> class="text-blue-600 focus:ring-blue-500">
                                <span class="text-sm text-gray-700 group-hover:text-blue-600"><%= item.category %></span>
                            </label>
                        <% }) %>
                    </div>
                </div>

                <!-- Filter Tahun -->
                <div class="mb-2">
                    <h4 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-3">Tahun Terbit</h4>
                    <select name="year" onchange="this.form.submit()" class="w-full text-sm border-gray-300 rounded focus:border-blue-500 focus:ring-blue-500">
                        <option value="">Semua Tahun</option>
                        <% sidebarData.years.forEach(item => { %>
                            <option value="<%= item.year %>" <%= query.year === item.year ? 'selected' : '' %>>
                                <%= item.year %>
                            </option>
                        <% }) %>
                    </select>
                </div>
            </form>
        </div>
    </aside>

    <!-- MAIN CONTENT (Kanan) -->
    <main class="w-full md:w-9/12">
        
        <!-- ADVANCED SEARCH BAR -->
        <div class="bg-blue-50 p-6 rounded-xl border border-blue-100 mb-8">
            <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center">
                <i class="fas fa-search text-blue-600 mr-2"></i> Pencarian Koleksi
            </h2>
            
            <form action="/search" method="GET" class="flex flex-col gap-3">
                <div class="flex flex-col md:flex-row gap-2">
                    
                    <!-- 1. Input Kata Kunci -->
                    <div class="flex-grow">
                        <input type="text" name="q" value="<%= query.q || '' %>"
                            class="w-full p-2.5 border border-gray-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
                            placeholder="Kata Kunci...">
                    </div>

                    <!-- 2. Dropdown Pilih Ruas -->
                    <div class="md:w-1/5">
                        <select name="searchBy" class="w-full p-2.5 bg-white border border-gray-300 rounded focus:ring-2 focus:ring-blue-500">
                            <option value="title" <%= query.searchBy === 'title' ? 'selected' : '' %>>Judul</option>
                            <option value="author" <%= query.searchBy === 'author' ? 'selected' : '' %>>Pengarang</option>
                            <option value="publisher" <%= query.searchBy === 'publisher' ? 'selected' : '' %>>Penerbit</option>
                            <option value="isbn" <%= query.searchBy === 'isbn' ? 'selected' : '' %>>ISBN</option>
                            <option value="subject" <%= query.searchBy === 'subject' ? 'selected' : '' %>>Subjek</option>
                        </select>
                    </div>

                    <!-- 3. Dropdown Tipe Pencocokan -->
                    <div class="md:w-1/5">
                        <select name="matchType" class="w-full p-2.5 bg-white border border-gray-300 rounded focus:ring-2 focus:ring-blue-500">
                            <option value="contains" <%= query.matchType === 'contains' ? 'selected' : '' %>>Default (Salah Satu Isi)</option>
                            <option value="startsWith" <%= query.matchType === 'startsWith' ? 'selected' : '' %>>Dimulai Dengan</option>
                            <option value="endsWith" <%= query.matchType === 'endsWith' ? 'selected' : '' %>>Diakhiri Dengan</option>
                            <option value="exact" <%= query.matchType === 'exact' ? 'selected' : '' %>>Tepat</option>
                        </select>
                    </div>

                    <!-- 4. Tombol Cari -->
                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded font-bold transition shadow-sm">
                        Cari
                    </button>
                </div>
            </form>
            
            <div class="mt-3 flex gap-4 text-xs text-gray-500">
                <a href="/" class="hover:text-blue-600"><i class="fas fa-undo mr-1"></i> Reset Pencarian</a>
                <a href="#" class="hover:text-blue-600"><i class="fas fa-history mr-1"></i> Riwayat Pencarian</a>
                <a href="#" class="hover:text-blue-600"><i class="fas fa-question-circle mr-1"></i> Bantuan</a>
            </div>
        </div>

        <!-- INFO HASIL -->
        <div class="mb-4 flex justify-between items-end border-b pb-2">
            <div>
                <h3 class="font-bold text-gray-700 text-lg">Daftar Koleksi</h3>
                <p class="text-xs text-gray-500">Menampilkan <%= books.length %> dari total <%= totalItems %> data</p>
            </div>
            <div class="flex gap-1">
                <button class="p-1 text-blue-600"><i class="fas fa-list"></i></button>
                <button class="p-1 text-gray-400"><i class="fas fa-th-large"></i></button>
            </div>
        </div>

        <!-- LIST BUKU -->
        <div class="space-y-4">
            <% if (books.length > 0) { %>
                <% books.forEach(book => { %>
                    <div class="bg-white p-4 rounded-lg border border-gray-200 hover:border-blue-400 hover:shadow-md transition flex flex-col sm:flex-row gap-4 group">
                        <!-- Cover -->
                        <div class="w-24 h-32 bg-gray-100 rounded flex-shrink-0 flex flex-col items-center justify-center text-gray-400 border border-gray-200 self-start">
                            <i class="fas fa-book text-3xl mb-1"></i>
                            <span class="text-[9px] text-center px-1">SAMPUL BELUM TERSEDIA</span>
                        </div>

                        <!-- Info -->
                        <div class="flex-grow text-sm">
                            <h4 class="text-base font-bold text-blue-700 group-hover:underline cursor-pointer mb-2" onclick="window.location.href='/book/<%= book.id %>'">
                                <%= book.title %>
                            </h4>
                            
                            <div class="grid grid-cols-1 gap-y-1 text-gray-600">
                                <div class="grid grid-cols-[100px_1fr]">
                                    <span class="font-semibold text-gray-700">Jenis Bahan</span>
                                    <span>: <%= book.category %></span>
                                </div>
                                <div class="grid grid-cols-[100px_1fr]">
                                    <span class="font-semibold text-gray-700">Pengarang</span>
                                    <span>: <a href="#" class="text-blue-600 hover:underline"><%= book.author %></a></span>
                                </div>
                                <div class="grid grid-cols-[100px_1fr]">
                                    <span class="font-semibold text-gray-700">Penerbitan</span>
                                    <span>: <%= book.publish_place %> : <%= book.publisher %>, <%= book.publish_year %></span>
                                </div>
                            </div>
                        </div>

                        <!-- Status Ketersediaan -->
                        <div class="sm:text-right flex flex-col justify-between sm:w-40 border-t sm:border-t-0 sm:border-l border-gray-100 sm:pl-4 pt-3 sm:pt-0 mt-2 sm:mt-0">
                            <div>
                                <span class="text-xs font-semibold text-gray-500 block mb-1">Ketersediaan</span>
                                <span class="text-xs text-blue-600 font-medium">
                                    <%= book.stock_available %> dari <%= book.stock_total %> eks.
                                </span>
                            </div>
                            <div class="mt-2">
                                <span class="px-2 py-1 bg-gray-100 text-gray-700 text-xs rounded border border-gray-300 font-mono inline-block">
                                    <%= book.call_number %>
                                </span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="p-10 text-center bg-gray-50 rounded border border-dashed border-gray-300">
                    <p class="text-gray-500 font-medium">Data tidak ditemukan.</p>
                </div>
            <% } %>
        </div>

        <!-- PAGINATION -->
        <% if (totalPages > 1) { %>
            <div class="mt-8 flex justify-center gap-1">
                <% for(let i = 1; i <= totalPages; i++) { %>
                    <a href="/search?q=<%= query.q %>&searchBy=<%= query.searchBy %>&matchType=<%= query.matchType %>&category=<%= query.category %>&year=<%= query.year %>&page=<%= i %>" 
                       class="px-3 py-1 border rounded text-sm <%= currentPage == i ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-gray-600 hover:bg-gray-50' %>">
                        <%= i %>
                    </a>
                <% } %>
            </div>
        <% } %>

    </main>
</div>

<%- include('partials/footer') %>