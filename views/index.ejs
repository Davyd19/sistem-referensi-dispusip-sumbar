<%- include('partials/header') %>

<!-- Bagian Pencarian -->
<div class="text-center mb-10">
    <h2 class="text-3xl font-bold text-gray-800 mb-2">Cari Buku Referensi</h2>
    <p class="text-gray-600 mb-6">Temukan koleksi referensi, skripsi, dan deposit daerah.</p>
    
    <form action="/search" method="GET" class="max-w-2xl mx-auto relative">
        <input type="text" name="q" value="<%= keyword %>"
            class="w-full pl-12 pr-4 py-4 rounded-xl border-2 border-gray-200 focus:border-blue-500 focus:ring-0 shadow-sm text-lg transition-all"
            placeholder="Ketik judul, pengarang, atau nomor panggil..." required>
        <button type="submit" class="absolute right-3 top-1/2 transform -translate-y-1/2 bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition">
            Cari
        </button>
        <div class="absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400">
            <i class="fas fa-search text-xl"></i>
        </div>
        
        <!-- Input hidden untuk kategori jika user klik tombol kategori -->
        <input type="hidden" name="category" id="categoryInput" value="<%= category %>">
    </form>

    <!-- Kategori Cepat -->
    <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href="/search?q=&category=Skripsi" class="px-4 py-2 bg-white border border-gray-200 rounded-full text-sm font-medium text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition shadow-sm">
            <i class="fas fa-graduation-cap mr-2 text-blue-500"></i>Skripsi
        </a>
        <a href="/search?q=&category=Ensiklopedia" class="px-4 py-2 bg-white border border-gray-200 rounded-full text-sm font-medium text-gray-700 hover:bg-green-50 hover:text-green-600 transition shadow-sm">
            <i class="fas fa-globe mr-2 text-green-500"></i>Ensiklopedia
        </a>
        <a href="/search?q=&category=Peraturan" class="px-4 py-2 bg-white border border-gray-200 rounded-full text-sm font-medium text-gray-700 hover:bg-red-50 hover:text-red-600 transition shadow-sm">
            <i class="fas fa-gavel mr-2 text-red-500"></i>Peraturan
        </a>
        <a href="/search?q=&category=Kamus" class="px-4 py-2 bg-white border border-gray-200 rounded-full text-sm font-medium text-gray-700 hover:bg-purple-50 hover:text-purple-600 transition shadow-sm">
            <i class="fas fa-book mr-2 text-purple-500"></i>Kamus
        </a>
    </div>
</div>

<!-- Bagian Hasil Pencarian -->
<% if (searched) { %>
    <div id="resultSection">
        <h3 class="text-lg font-semibold text-gray-700 mb-4">
            Hasil Pencarian: <%= books.length %> buku ditemukan
            <% if(category) { %> dalam kategori "<%= category %>" <% } %>
        </h3>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% if (books.length > 0) { %>
                <% books.forEach(book => { %>
                    <div class="bg-white p-5 rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition cursor-pointer flex items-start group" 
                         onclick="window.location.href='/book/<%= book.id %>'">
                        
                        <div class="bg-gray-100 w-16 h-24 rounded flex-shrink-0 mr-4 flex items-center justify-center text-gray-400">
                            <i class="fas fa-book text-2xl"></i>
                        </div>
                        
                        <div class="flex-grow">
                            <div class="flex justify-between items-start">
                                <span class="text-xs font-bold text-blue-600 uppercase tracking-wide mb-1"><%= book.category %></span>
                                <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded font-mono"><%= book.call_number %></span>
                            </div>
                            <h4 class="font-bold text-gray-900 leading-tight group-hover:text-blue-600 transition line-clamp-2">
                                <%= book.title %>
                            </h4>
                            <p class="text-sm text-gray-500 mt-1"><%= book.author %></p>
                            <div class="mt-3 flex items-center text-xs text-gray-400">
                                <i class="fas fa-map-marker-alt mr-1"></i> Klik untuk lihat lokasi
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-2 text-center py-10 bg-white rounded-xl border border-dashed border-gray-300">
                    <p class="text-gray-500">Maaf, buku yang Anda cari tidak ditemukan.</p>
                    <a href="/" class="text-blue-600 text-sm mt-2 hover:underline">Reset Pencarian</a>
                </div>
            <% } %>
        </div>
    </div>
<% } %>

<%- include('partials/footer') %>