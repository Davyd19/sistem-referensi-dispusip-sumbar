<%- include('partials/header') %>

<div class="mb-4">
    <a href="javascript:history.back()" class="text-gray-500 hover:text-blue-600 flex items-center text-sm font-medium">
        <i class="fas fa-arrow-left mr-2"></i> Kembali ke Pencarian
    </a>
</div>

<div class="bg-white rounded-2xl shadow-lg w-full overflow-hidden flex flex-col md:flex-row border border-gray-200">
    
    <!-- Kiri: Info Buku -->
    <div class="p-8 md:w-1/2 border-b md:border-b-0 md:border-r border-gray-100">
        <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-xs font-bold uppercase tracking-wide mb-4 inline-block">
            <%= book.category %>
        </span>
        
        <h2 class="text-3xl font-bold text-gray-900 mb-2 leading-tight"><%= book.title %></h2>
        <p class="text-xl text-gray-600 mb-6"><%= book.author %></p>

        <div class="space-y-4">
            <!-- Call Number -->
            <div class="flex items-center p-4 bg-gray-50 rounded-xl border border-gray-100">
                <div class="w-12 h-12 rounded-full bg-orange-100 flex items-center justify-center text-orange-600 mr-4 text-xl">
                    <i class="fas fa-barcode"></i>
                </div>
                <div>
                    <p class="text-xs text-gray-500 uppercase font-bold">Nomor Panggil (Call Number)</p>
                    <p class="text-2xl font-mono font-bold text-gray-900"><%= book.call_number %></p>
                    <p class="text-xs text-red-500 italic mt-1">*Catat nomor ini untuk mencari di rak</p>
                </div>
            </div>

            <!-- Publisher Info -->
            <div class="flex items-center p-4 bg-gray-50 rounded-xl border border-gray-100">
                <div class="w-12 h-12 rounded-full bg-green-100 flex items-center justify-center text-green-600 mr-4 text-xl">
                    <i class="fas fa-building"></i>
                </div>
                <div>
                    <p class="text-xs text-gray-500 uppercase font-bold">Penerbit & Tahun</p>
                    <p class="text-base font-medium text-gray-900">
                        <%= book.publisher %>, <%= book.publish_year %>
                    </p>
                    <% if(book.isbn) { %>
                        <p class="text-xs text-gray-400 mt-1">ISBN: <%= book.isbn %></p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Kanan: Peta Lokasi -->
    <div class="p-8 md:w-1/2 bg-gray-50 flex flex-col">
        <h3 class="text-sm font-bold text-gray-500 uppercase tracking-wider mb-4 flex items-center">
            <i class="fas fa-map-marker-alt mr-2 text-red-500"></i> 
            Lokasi Buku: <span class="text-blue-600 ml-1 text-lg">Rak <%= book.shelf_location %></span>
        </h3>
        
        <!-- Container Peta Visual -->
        <div class="flex-grow bg-white border border-gray-200 rounded-xl p-6 shadow-sm relative min-h-[300px]">
            <div class="absolute top-2 left-2 text-xs text-gray-400 font-bold border px-2 py-1 rounded">Pintu Masuk</div>
            
            <!-- Simulasi Layout Ruangan (Grid) -->
            <div class="mt-10 space-y-6">
                
                <!-- Baris Rak A -->
                <div class="flex gap-4 justify-between">
                    <!-- Logic EJS: Jika lokasi buku == A1, tambahkan class 'active' -->
                    <div class="shelf w-1/3 h-16 bg-slate-200 rounded flex items-center justify-center text-slate-500 font-bold <%= book.shelf_location == 'A1' ? 'active' : '' %>">
                        Rak A1
                    </div>
                    <div class="shelf w-1/3 h-16 bg-slate-200 rounded flex items-center justify-center text-slate-500 font-bold <%= book.shelf_location == 'A2' ? 'active' : '' %>">
                        Rak A2
                    </div>
                    <div class="shelf w-1/3 h-16 bg-slate-200 rounded flex items-center justify-center text-slate-500 font-bold <%= book.shelf_location == 'A3' ? 'active' : '' %>">
                        Rak A3
                    </div>
                </div>

                <!-- Gang Jalan -->
                <div class="h-8 w-full bg-transparent flex items-center justify-center text-xs text-gray-300 tracking-[0.5em]">JALAN</div>

                 <!-- Baris Rak B -->
                 <div class="flex gap-4 justify-between">
                    <div class="shelf w-1/3 h-16 bg-slate-200 rounded flex items-center justify-center text-slate-500 font-bold <%= book.shelf_location == 'B1' ? 'active' : '' %>">
                        Rak B1
                    </div>
                    <div class="shelf w-1/3 h-16 bg-slate-200 rounded flex items-center justify-center text-slate-500 font-bold <%= book.shelf_location == 'B2' ? 'active' : '' %>">
                        Rak B2
                    </div>
                    <div class="shelf w-1/3 h-16 bg-slate-200 rounded flex items-center justify-center text-slate-500 font-bold <%= book.shelf_location == 'B3' ? 'active' : '' %>">
                        Rak B3
                    </div>
                </div>

                 <!-- Area Baca -->
                 <div class="mt-8 border-2 border-dashed border-gray-300 rounded-lg h-20 flex items-center justify-center text-gray-400 text-sm bg-slate-50">
                    <i class="fas fa-chair mr-2"></i> Area Meja Baca
                 </div>
            </div>
        </div>

        <div class="mt-4 p-3 bg-blue-50 text-blue-800 text-xs rounded-lg flex items-start">
            <i class="fas fa-info-circle mt-0.5 mr-2"></i>
            <p>Perhatikan blok rak yang berkedip biru di peta. Itu adalah lokasi penyimpanan buku ini. Buku referensi tidak dapat dibawa pulang.</p>
        </div>
    </div>
</div>

<%- include('partials/footer') %>